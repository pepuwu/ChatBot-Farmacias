# Base de datos PostgreSQL (Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-nano

# Telegram — bot del super-admin (tuyo). Para gestionar farmacias y ver estado.
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_SUPER_ADMIN_ID=123456789

# WhatsApp admin — número que recibe comandos de todos los farmacéuticos.
# Es el número de la sesión Baileys "admin". Identifica con JID tipo: 5491112345678
ADMIN_WHATSAPP_NUMBER=5491112345678

# Servidor Fastify (health check)
PORT=8080
HOST=0.0.0.0

# Sesiones de Baileys — directorio donde se guarda la auth de cada número
SESSIONS_DIR=./sessions

# Nivel de log (trace | debug | info | warn | error)
LOG_LEVEL=info
