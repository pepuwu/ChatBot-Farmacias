{
  "name": "chatbot-farmacias",
  "version": "1.0.0",
  "description": "Sistema multi-farmacia: bot WhatsApp para clientes (Baileys) + bot Telegram para super-admin (Telegraf). Farmacéuticos operan via WhatsApp admin.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@whiskeysockets/baileys": "^6.7.8",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "openai": "^4.73.0",
    "pino": "^9.5.0",
    "qrcode-terminal": "^0.12.0",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
